# NeurIPS / ICLR: single-column, 10pt body font (textwidth 5.5 in).
# ICML uses the same body font but has its own sheet (icml.mplstyle) so
# two-column-specific tweaks stay isolated.
# This sheet only sets font sizes; widths live in widths.json.
# Tick / legend sizes sit ~2pt below body.

font.size:         8
axes.labelsize:    8
axes.titlesize:    8
legend.fontsize:   7
xtick.labelsize:   7
ytick.labelsize:   7
figure.titlesize:  8
