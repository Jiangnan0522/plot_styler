# 10pt body font templates:
#   NeurIPS, ICLR  — single-column (textwidth 5.5 in)
#   ICML           — two-column    (columnwidth 3.25 in, textwidth 6.75 in)
# This sheet only sets font sizes; widths live in widths.json.
# Tick / legend sizes sit ~2pt below body.

font.size:         8
axes.labelsize:    8
axes.titlesize:    8
legend.fontsize:   7
xtick.labelsize:   7
ytick.labelsize:   7
figure.titlesize:  8
